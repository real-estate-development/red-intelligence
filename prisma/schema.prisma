generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  /// Resolved relative to the `prisma/` directory (`../data/app.db` → repo `data/app.db`).
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  username     String   @unique
  passwordHash String
  isAdmin      Boolean  @default(false)
  createdAt    DateTime @default(now())
}

/// Building row from GWR-style CSV ingest (`scripts/gwr-ingest.ts`).
model Building {
  id        String   @id @default(cuid())
  egid      String   @unique
  address   String
  yearBuilt Int
  lat       Float
  lng       Float
  createdAt DateTime @default(now())

  @@index([lat, lng])
}
