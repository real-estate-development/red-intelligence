# Copy to `.env` for local development and production.

# SQLite file at repository `data/app.db` (path relative to `prisma/`).
DATABASE_URL="file:../data/app.db"

# iron-session: minimum 32 random characters (generate e.g. `openssl rand -hex 32`).
SESSION_PASSWORD="replace-with-32-or-more-random-characters-min"

# Seed admin user: `npm run db:seed` (requires SEED_ADMIN_PASSWORD).
SEED_ADMIN_USERNAME="admin"
SEED_ADMIN_PASSWORD="choose-a-strong-password"

# GWR: BFS MADD public ZIP (see https://www.housing-stat.ch/de/data/supply/public.html).
# Default scope is Switzerland (`ch`, large download). Use a canton code for a smaller ZIP, e.g.:
# GWR_BFS_SCOPE=tg
# Optional override of ZIP host (default https://public.madd.bfs.admin.ch):
# GWR_BFS_PUBLIC_BASE="https://public.madd.bfs.admin.ch"

# Optional: release year for `npm run footprints:tlmregio-join` STAC download (default 2025).
# SWISSTLMREGIO_YEAR="2025"
# Optional: directory for downloaded zip + extracted GeoPackage (default data/swisstlmregio).
# SWISSTLMREGIO_DATA_DIR="data/swisstlmregio"

# Optional: STAC item id for `npm run footprints:tlm3d-join` (default swisstlm3d_2025-03).
# SWISSTLM3D_RELEASE="swisstlm3d_2025-03"
# SWISSTLM3D_DATA_DIR="data/swisstlm3d"
# SWISSTLM3D_GRID_DEG="0.15"
# SWISSTLM3D_BUFFER_DEG="0.002"
# SWISSTLM3D_SNAP_M="2"

# Optional: building footprint GeoJSON URL for `npm run footprints:ingest` when --url/--file is omitted.
# Must be a GeoJSON FeatureCollection of Polygon/MultiPolygon features with EGID property.
# FOOTPRINTS_GEOJSON_URL="https://example.invalid/footprints.geojson"

# Optional defaults for swissBUILDINGS3D STAC downloader pipeline.
# SWISSBUILDINGS3D_BBOX="7.55,47.53,7.63,47.58"
# SWISSBUILDINGS3D_OUT_DIR="data/swissbuildings3d"
# SWISSBUILDINGS3D_ITEM_LIMIT="200"

# Optional defaults for swissBUILDINGS3D conversion stage.
# SWISSBUILDINGS3D_MANIFEST="data/swissbuildings3d/manifest.json"
# SWISSBUILDINGS3D_GEOJSON_OUT="data/swissbuildings3d/footprints.geojsonseq"
# SWISSBUILDINGS3D_WORK_DIR="data/swissbuildings3d/work"
# SWISSBUILDINGS3D_CONVERT_CONCURRENCY="4"
# Set only when you intentionally want an incomplete footprint extract despite failed tiles.
# SWISSBUILDINGS3D_ALLOW_PARTIAL="1"
# Optional: override GDAL Docker image used when local ogr2ogr is missing.
# SWISSBUILDINGS3D_GDAL_DOCKER_IMAGE="ghcr.io/osgeo/gdal:ubuntu-small-latest"

# Ingest: `npm run gwr:ingest` (replace DB buildings) or `npm run gwr:ingest -- --append`
# CLI: `--scope tg`, `--zip /path/to.zip`, `--file /path/to/gebaeude_batiment_edificio.csv`, `--url https://…/zip`
# Per-canton mean/median year & mean age: `npm run gwr:canton-stats` (needs `canton` on rows; set by ingest from GWR `gdekt`)

# Phase 1–3 building-age overlay (EGID join → PMTiles → MapLibre):
#   npm run etl:gwr-ch          # national GWR CSV (~900 MB ZIP)
#   npm run etl:tlm3d-bauperiode  # full CH: swissTLM3D footprints + GWR GBAUP (recommended)
#   npm run etl:pmtiles -- data/etl/tlm3d_bauperiode.geojsonseq public/tiles/swiss_buildings.pmtiles
#   npm run etl:switzerland     # legacy swissBUILDINGS3D STAC path (can have internal gaps)
# NEXT_PUBLIC_BUILDINGS_PMTILES_URL="pmtiles:///tiles/swiss_buildings.pmtiles"
# Optional: TLM3D_JOIN_SNAP_M="10"
